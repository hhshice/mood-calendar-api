# 数据库 (TiDB Serverless)
DATABASE_URL=mysql+pymysql://user:password@host:4000/mood_calendar?charset=utf8mb4

# 微信小程序
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_app_secret

# JWT
SECRET_KEY=your_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mood-calendar-images
R2_PUBLIC_URL=
